# ─── Required ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Crypto / Audit ───────────────────────────
# 32-byte hex master key — generate: python -c "import secrets; print(secrets.token_hex(32))"
AUDIT_MASTER_KEY=your-64-char-hex-key-here
CANARY_SECRET_KEY=your-64-char-hex-key-here

# ─── HashiCorp Vault ──────────────────────────
VAULT_ADDR=https://vault.yourdomain.com:8200
VAULT_TOKEN=your-vault-token
VAULT_ROLE_ID=your-approle-role-id
VAULT_SECRET_ID=your-approle-secret-id

# ─── Local Model / Air-Gap ────────────────────
OLLAMA_HOST=http://localhost:11434
LOCAL_MODEL_NAME=llama3.1:70b
ENABLE_LOCAL_MODEL_FALLBACK=true

# ─── Redis Rate Limiter ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Detection thresholds ─────────────────────────────────
BLOCK_THRESHOLD=65.0
WARN_THRESHOLD=35.0
SEMANTIC_TRIGGER_THRESHOLD=15.0
EMBEDDING_TRIGGER_THRESHOLD=0.55

# ─── Layer weights (must sum to 1.0) ──────────────────────
RULE_ENGINE_WEIGHT=0.20
EMBEDDING_WEIGHT=0.15
SEMANTIC_WEIGHT=0.45
CONTEXT_WEIGHT=0.20

# ─── Feature flags ────────────────────────────────────────
ENABLE_RULE_ENGINE=true
ENABLE_EMBEDDING_DETECTOR=true
ENABLE_SEMANTIC_CLASSIFIER=true
ENABLE_CONTEXT_ANALYZER=true
ENABLE_OUTPUT_SCANNER=true
ENABLE_CANARY_TOKENS=true
ENABLE_ATLAS_MAPPING=true
ENABLE_PARALLEL_ENSEMBLE=true
DEMO_MODE=true

# ─── Persistence ──────────────────────────────────────────
SECURE_AUDIT_DB_PATH=data/secure_audit.db
METRICS_DB_PATH=data/metrics.db
